# project-management — environment variables
# Copy to ".env" and fill in YOUR values. Never commit the real .env.
# ALL of these are OPTIONAL: with none set, everything runs OFFLINE against a
# local board.json. Set one provider's vars to sync to that tool.

# Force a provider. Leave blank to auto-detect: trello if TRELLO_* set,
# jira if JIRA_* set, else local.   Values: local | trello | jira
PM_PROVIDER=

# --- Trello (https://trello.com/app-key) ---
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=          # the <id> in https://trello.com/b/<id>/<slug>

# --- Jira Cloud (https://id.atlassian.com/manage-profile/security/api-tokens) ---
JIRA_BASE_URL=            # e.g. https://yourorg.atlassian.net
JIRA_EMAIL=               # your Atlassian account email
JIRA_API_TOKEN=           # an API token (NOT your password)
JIRA_PROJECT_KEY=         # e.g. PROJ
